{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ease-design/schemas/generation-contract.schema.json",
  "title": "ease-design generation contract",
  "type": "object",
  "required": ["kind", "version", "briefRef", "direction", "sections", "viewports", "requiredGates", "output"],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "generation-contract" },
    "version": { "const": 1 },
    "briefRef": { "type": "string", "minLength": 1 },
    "direction": {
      "type": "object", "required": ["thesis", "structure", "focalMechanism", "signatureDevice", "risk"], "additionalProperties": false,
      "properties": {
        "thesis": { "type": "string", "minLength": 1 },
        "structure": { "type": "string", "minLength": 1 },
        "focalMechanism": { "type": "string", "minLength": 1 },
        "signatureDevice": { "type": "string", "minLength": 1 },
        "risk": { "type": "string", "minLength": 1 }
      }
    },
    "sections": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "viewports": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
    "requiredGates": { "type": "array", "items": { "type": "string" } },
    "output": { "enum": ["html"] }
  }
}

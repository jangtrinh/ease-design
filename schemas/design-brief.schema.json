{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ease-design/schemas/design-brief.schema.json",
  "title": "ease-design qualified delivery brief",
  "type": "object",
  "required": ["kind", "version", "rawRequest", "surface", "audience", "context", "primaryOutcome", "primaryAction", "requiredContent", "constraints", "prohibitedClaims", "criteria", "assumptions"],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "design-brief" },
    "version": { "const": 1 },
    "rawRequest": { "type": "string", "minLength": 1 },
    "surface": { "enum": ["marketing-landing"] },
    "audience": { "type": "string", "minLength": 1 },
    "context": { "type": "string", "minLength": 1 },
    "primaryOutcome": { "type": "string", "minLength": 1 },
    "primaryAction": { "type": "string", "minLength": 1 },
    "requiredContent": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "constraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "prohibitedClaims": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "criteria": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["id", "priority", "text"], "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "priority": { "enum": ["must", "should"] },
          "text": { "type": "string", "minLength": 1 },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object", "required": ["facet", "value", "provenance", "confidence"], "additionalProperties": false,
        "properties": {
          "facet": { "type": "string", "minLength": 1 },
          "value": { "type": "string", "minLength": 1 },
          "provenance": { "enum": ["provided", "project-evidence", "inferred", "unknown"] },
          "confidence": { "enum": ["high", "medium", "low"] }
        }
      }
    }
  }
}

{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "typeRoots": ["../node_modules/@figma", "../../node_modules/@figma"],
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*.ts", "../shared/**/*.ts"]
}

{
  "name": "ease-design",
  "version": "0.0.0",
  "description": "Multi-runtime design-cli — describe what you want, get pro-taste UI.",
  "type": "module",
  "bin": {
    "ui": "./dist/cli.js"
  },
  "files": [
    "dist",
    "knowledge",
    "schemas",
    "templates"
